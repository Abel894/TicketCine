<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TicketCine.Web</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TicketCine.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark tc-navbar box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand tc-navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">TicketCine</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link tc-nav-link" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link tc-nav-link" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                    </ul>
                    <ul class="navbar-nav ms-auto">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle tc-nav-link" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    @User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end tc-dropdown-menu">
                                    <li><a class="dropdown-item tc-dropdown-item" asp-controller="Reserva" asp-action="MisReservas">Mis reservas</a></li>
                                    <li><a class="dropdown-item tc-dropdown-item" asp-controller="Reserva" asp-action="Historial">Historial</a></li>
                                    @if (User.IsInRole("Administrador"))
                                    {
                                        <li><a class="dropdown-item tc-dropdown-item" asp-controller="AdminUsuarios" asp-action="Index">Gestión de Usuarios</a></li>
                                        <li><a class="dropdown-item tc-dropdown-item" asp-controller="AdminReportes" asp-action="Index">Reportes</a></li>
                                    }
                                    <li><a class="dropdown-item tc-dropdown-item" href="#">Mi Perfil</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item tc-dropdown-item" asp-controller="Auth" asp-action="Logout">Cerrar Sesión</a></li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link tc-nav-link" asp-controller="Auth" asp-action="Login">Iniciar Sesión</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link tc-nav-link" asp-controller="Auth" asp-action="Registro">Registrarse</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer tc-footer">
        <div class="container">
            &copy; 2026 - TicketCine.Web - <a class="tc-footer-link" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>