@model List<SalaResponse>
@{
    ViewData["Title"] = "Gestión de Salas - TicketCine";
}

<div class="container-fluid mt-5">
    <div class="row mb-4">
        <div class="col-md-12">
            <h1>Gestión de Salas</h1>
        </div>
    </div>

    <!-- Mensajes de éxito/error -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Botón de crear -->
    <div class="row mb-4">
        <div class="col-md-12">
            <a href="@Url.Action("Crear")" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Crear Nueva Sala
            </a>
        </div>
    </div>

    <!-- Tabla de salas -->
    @if (Model == null || Model.Count == 0)
    {
        <div class="alert alert-info">
            No hay salas registradas.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Nombre</th>
                        <th>Filas</th>
                        <th>Columnas</th>
                        <th>Total Asientos</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var sala in Model)
                    {
                        var totalAsientos = sala.Filas * sala.Columnas;
                        <tr>
                            <td>
                                <strong>@sala.Nombre</strong>
                            </td>
                            <td>@sala.Filas</td>
                            <td>@sala.Columnas</td>
                            <td>@totalAsientos</td>
                            <td>
                                @if (sala.Activo)
                                {
                                    <span class="badge bg-success">Activa</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Inactiva</span>
                                }
                            </td>
                            <td>
                                <a href="@Url.Action("Editar", new { id = sala.Id })" class="btn btn-warning btn-sm">
                                    Editar
                                </a>

                                <form method="post" action="@Url.Action("Eliminar", new { id = sala.Id })" 
                                      style="display: inline;" 
                                      onsubmit="return confirm('¿Estás seguro de que deseas eliminar esta sala?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-danger btn-sm">
                                        Eliminar
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@section Scripts {
    <!-- Scripts específicos si es necesario -->
}
