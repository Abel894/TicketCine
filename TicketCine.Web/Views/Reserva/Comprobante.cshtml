@model TicketCine.Web.Models.ComprobanteViewModel
@{
    ViewData["Title"] = "Comprobante de Compra";
}

<div class="container mt-4 mb-4">
    <div class="row justify-content-center">
        <div class="col-lg-9">
            <div class="card card-cine shadow">
                <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Comprobante de Compra</h5>
                    <span class="badge bg-light text-success">Venta: @Model.VentaId</span>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-7">
                            <p class="mb-1"><strong>Película:</strong> @Model.TituloPelicula</p>
                            <p class="mb-1"><strong>Sala:</strong> @Model.NombreSala</p>
                            <p class="mb-1"><strong>Función:</strong> @Model.FechaHoraFuncion.ToString("dd/MM/yyyy HH:mm")</p>
                            <p class="mb-1"><strong>Asientos:</strong> @string.Join(", ", Model.Asientos)</p>
                            <p class="mb-1"><strong>Monto total:</strong> S/ @Model.MontoTotal.ToString("N2")</p>
                            <p class="mb-1"><strong>Método de pago:</strong> @Model.MetodoPago</p>
                            <p class="mb-0"><strong>Fecha de venta:</strong> @Model.FechaVenta.ToString("dd/MM/yyyy HH:mm")</p>
                        </div>
                        <div class="col-md-5 text-center">
                            <div class="tc-qr-panel rounded p-3">
                                <img src="data:image/png;base64,@Model.CodigoQrBase64" alt="Código QR" class="img-fluid" style="max-width: 280px;" />
                                <div class="small text-muted mt-2">Código: @Model.CodigoQr</div>
                            </div>
                            <a class="btn tc-btn-outline-gold btn-sm mt-3"
                               href="data:image/png;base64,@Model.CodigoQrBase64"
                               download="ticketcine-qr-@(Model.VentaId).png">Descargar QR</a>
                        </div>
                    </div>
                </div>
                <div class="card-footer tc-card-footer d-flex justify-content-between">
                    <a asp-controller="Catalogo" asp-action="Index" class="btn tc-btn-outline-gold">Volver a cartelera</a>
                    <button type="button" class="btn btn-cine" onclick="window.print();">Imprimir</button>
                </div>
            </div>
        </div>
    </div>
</div>