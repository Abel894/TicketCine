@model TicketCine.Web.Models.MisReservasViewModel
@{
    ViewData["Title"] = "Mis Reservas";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="mb-0">Mis Reservas</h3>
        <a asp-controller="Catalogo" asp-action="Index" class="btn btn-cine btn-sm">Ir a cartelera</a>
    </div>

    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="alert alert-success">@successMessage</div>
    }

    @if (TempData["ErrorMessage"] is string errorMessage)
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    @if (!Model.Reservas.Any())
    {
        <div class="alert tc-empty-state">No tienes reservas activas.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-cine align-middle">
                <thead>
                    <tr>
                        <th>Código</th>
                        <th>Película</th>
                        <th>Función</th>
                        <th>Asientos</th>
                        <th>Estado</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Reservas)
                    {
                        <tr>
                            <td><code>@item.CodigoReserva</code></td>
                            <td>
                                <div class="fw-semibold">@item.TituloPelicula</div>
                                <small class="text-muted">@item.NombreSala</small>
                            </td>
                            <td>@item.FechaHoraFuncion.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@string.Join(", ", item.Asientos)</td>
                            <td>
                                @if (item.Estado == EstadoReserva.Pendiente)
                                {
                                    <span class="badge bg-warning text-dark">Pendiente</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Confirmada</span>
                                }
                            </td>
                            <td class="text-end">
                                @if (item.Estado == EstadoReserva.Pendiente)
                                {
                                    <a asp-action="Resumen" asp-route-id="@item.ReservaId" class="btn btn-cine btn-sm me-2 @(item.PuedeContinuarPago ? "" : "disabled")">Continuar pago</a>
                                    <button type="button"
                                            class="btn btn-sm btn-outline-danger"
                                            data-bs-toggle="modal"
                                            data-bs-target="#cancelarModal"
                                            data-reserva-id="@item.ReservaId"
                                            data-codigo="@item.CodigoReserva"
                                        @(item.PuedeCancelar ? null : "disabled")>
                                        Cancelar
                                    </button>
                                }
                                else if (item.VentaId.HasValue)
                                {
                                    <a asp-action="Comprobante" asp-route-id="@item.VentaId.Value" class="btn btn-cine btn-sm">Ver comprobante</a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<div class="modal fade" id="cancelarModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Confirmar cancelación</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                ¿Seguro que deseas cancelar la reserva <strong id="codigoReservaCancelar">-</strong>?
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">No, volver</button>
                <form method="post" asp-action="Cancelar">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="reservaIdCancelar" name="reservaId" />
                    <button type="submit" class="btn btn-danger">Sí, cancelar reserva</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const cancelarModal = document.getElementById('cancelarModal');
        cancelarModal.addEventListener('show.bs.modal', function(event) {
            const button = event.relatedTarget;
            const reservaId = button.getAttribute('data-reserva-id');
            const codigo = button.getAttribute('data-codigo');

            document.getElementById('reservaIdCancelar').value = reservaId;
            document.getElementById('codigoReservaCancelar').textContent = codigo;
        });
    </script>
}