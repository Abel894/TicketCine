@model List<FuncionDetalleResponse>
@{
    ViewData["Title"] = "Funciones - TicketCine";
    var peliculaId = ViewBag.PeliculaId as Guid?;
    string tituloPelicula = ViewBag.TituloPelicula;
}

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-12">
            <a href="@Url.Action("Index", "Catalogo")" class="btn btn-secondary btn-sm">
                &larr; Volver a Cartelera
            </a>
            <h1 class="mt-3">Funciones: @tituloPelicula</h1>
        </div>
    </div>

    @if (Model == null || Model.Count == 0)
    {
        <div class="alert alert-info">
            No hay funciones disponibles para esta película en este momento.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Sala</th>
                        <th>Fecha</th>
                        <th>Hora</th>
                        <th>Precio</th>
                        <th>Asientos Disponibles</th>
                        <th>Acción</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var funcion in Model)
                    {
                        var disponibilidad = funcion.AsientosDisponibles > 0 
                            ? $"{funcion.AsientosDisponibles} de {funcion.TotalAsientos}" 
                            : "Agotado";

                        var claseDisponibilidad = funcion.AsientosDisponibles > 0 
                            ? "badge bg-success" 
                            : "badge bg-danger";

                        <tr>
                            <td>@funcion.NombreSala</td>
                            <td>@funcion.FechaHora.ToString("dd/MM/yyyy")</td>
                            <td>@funcion.FechaHora.ToString("HH:mm")</td>
                            <td>
                                <strong>$@funcion.Precio.ToString("N2")</strong>
                            </td>
                            <td>
                                <span class="@claseDisponibilidad">@disponibilidad</span>
                            </td>
                            <td>
                                @if (funcion.AsientosDisponibles > 0)
                                {
                                    <a href="@Url.Action("Asientos", new { funcionId = funcion.Id })" class="btn btn-primary btn-sm">
                                        Elegir asientos
                                    </a>
                                }
                                else
                                {
                                    <button type="button" class="btn btn-secondary btn-sm" disabled>
                                        Agotado
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@section Scripts {
    <!-- Scripts específicos si es necesario -->
}
